# Public — set to override the auto-detected site URL.
# Leave unset for production (defaults to https://pitwallapex.com).
# Local dev: http://localhost:3000
# Vercel preview: automatically detected via VERCEL_URL
# Production: https://pitwallapex.com (fallback when unset)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin dashboard (required for /admin)
ADMIN_USERNAME=founder
ADMIN_PASSWORD=change-me-in-production
ADMIN_SESSION_SECRET=generate-a-long-random-string-at-least-32-chars

# Analytics storage (optional override)
# Omitted in development → file (JSONL under data/analytics/)
# Omitted in production → supabase
# ANALYTICS_STORE=file
# ANALYTICS_STORE=supabase

# Supabase (required in production for analytics persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
